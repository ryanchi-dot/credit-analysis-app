/* pages/chat/chat.wxss */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.chat-container {
  flex: 1;
  padding: 20rpx;
  overflow-y: scroll;
}

.message-row {
  display: flex;
  margin-bottom: 30rpx;
  align-items: flex-start;
}

/* 用户消息（右侧） */
.user-message {
  flex-direction: row-reverse;
}

.user-content {
  background-color: #1890ff;
  color: #fff;
  border-radius: 20rpx 20rpx 0 20rpx;
  margin-right: 20rpx;
  max-width: 70%;
}

/* Assistant 消息（左侧） */
.assistant-message {
  flex-direction: row;
}

.assistant-content {
  background-color: #fff;
  color: #333;
  border-radius: 20rpx 20rpx 20rpx 0;
  margin-left: 20rpx;
  max-width: 70%;
}

.message-content {
  padding: 20rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.message-text {
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-all;
  white-space: pre-wrap;
}

.typing {
  color: #999;
  font-style: italic;
}

/* 头像 */
.avatar {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-text {
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
}

.user-avatar {
  background-color: #1890ff;
}

.assistant-avatar {
  background-color: #52c41a;
}

/* 输入区域 */
.input-container {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #fff;
  border-top: 2rpx solid #e0e0e0;
}

.input-box {
  flex: 1;
  height: 70rpx;
  padding: 0 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 35rpx;
  font-size: 28rpx;
  margin-right: 20rpx;
}

.send-btn {
  width: 120rpx;
  height: 70rpx;
  line-height: 70rpx;
  font-size: 28rpx;
  border-radius: 35rpx;
}

/* 操作按钮 */
.actions {
  display: flex;
  justify-content: center;
  padding: 10rpx;
  background-color: #f5f5f5;
}

.clear-btn {
  font-size: 24rpx;
  color: #999;
  background-color: #fff;
}

<!--pages/chat/chat.wxml-->
<view class="container">
  <!-- 聊天记录区域 -->
  <scroll-view
    class="chat-container"
    scroll-y
    scroll-top="{{scrollTop}}"
    scroll-into-view="{{toView}}"
    scroll-with-animation
  >
    <block wx:for="{{messages}}" wx:key="index">
      <!-- 用户消息 -->
      <view class="message-row user-message" wx:if="{{item.role === 'user'}}" id="msg-{{index}}">
        <view class="message-content user-content">
          <text class="message-text">{{item.content}}</text>
        </view>
        <view class="avatar user-avatar">
          <text class="avatar-text">我</text>
        </view>
      </view>

      <!-- Assistant 消息 -->
      <view class="message-row assistant-message" wx:else id="msg-{{index}}">
        <view class="avatar assistant-avatar">
          <text class="avatar-text">AI</text>
        </view>
        <view class="message-content assistant-content">
          <text class="message-text">{{item.content}}</text>
        </view>
      </view>
    </block>

    <!-- 加载中提示 -->
    <view class="message-row assistant-message" wx:if="{{loading}}">
      <view class="avatar assistant-avatar">
        <text class="avatar-text">AI</text>
      </view>
      <view class="message-content assistant-content">
        <text class="typing">正在思考...</text>
      </view>
    </view>
  </scroll-view>

  <!-- 输入区域 -->
  <view class="input-container">
    <input
      class="input-box"
      placeholder="请输入你的问题..."
      value="{{inputText}}"
      bindinput="onInput"
      bindconfirm="onSend"
      confirm-type="send"
      disabled="{{loading}}"
    />
    <button
      class="send-btn"
      bindtap="onSend"
      loading="{{loading}}"
      disabled="{{loading || !inputText}}"
    >
      发送
    </button>
  </view>

  <!-- 清空历史按钮 -->
  <view class="actions" wx:if="{{messages.length > 0}}">
    <button class="clear-btn" bindtap="onClear" size="mini">清空对话</button>
  </view>
</view>

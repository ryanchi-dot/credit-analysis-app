# ==================== Telegram Bot 配置 ====================
# Telegram Bot Token (从 @BotFather 获取)
# 获取方式：
# 1. 在 Telegram 中搜索 @BotFather
# 2. 发送 /newbot 创建新机器人
# 3. 按照提示设置机器人名称和用户名
# 4. BotFather 会返回一个 Token，格式如：123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ==================== Coze 智能体配置 ====================
# Coze Bot ID (智能体 ID)
# 获取方式：
# 1. 访问 https://www.coze.cn/
# 2. 创建或选择一个智能体
# 3. 在智能体设置中找到 Bot ID
COZE_BOT_ID=your_coze_bot_id_here

# Coze API Key (API 密钥)
# 获取方式：
# 1. 访问 https://www.coze.cn/
# 2. 进入个人中心 -> API 管理
# 3. 创建新的 API Key
COZE_API_KEY=your_coze_api_key_here

# ==================== Coze 工作空间配置（可选）====================
# Coze Workspace ID (工作空间 ID)
# 获取方式：
# 1. 访问 https://www.coze.cn/
# 2. 在工作空间设置中找到 Workspace ID
COZE_WORKSPACE_ID=your_workspace_id_here

# Coze PAT Token (Personal Access Token，可选)
# 获取方式：
# 1. 访问 https://www.coze.cn/
# 2. 进入个人中心 -> API 管理
# 3. 创建 PAT Token
COZE_PAT_TOKEN=your_pat_token_here
